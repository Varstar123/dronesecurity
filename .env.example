# Copy this file to ".env" and fill in what you need.

# ---- AI analysis --------------------------------------------------
# Provider is auto-picked: GROQ_API_KEY -> Groq, else ANTHROPIC_API_KEY -> Claude,
# else offline SIMULATION (works fully with no key — pick scenarios in the drone app).

# Option A: Groq (fast + free tier). Get a key: https://console.groq.com/keys
GROQ_API_KEY=
# Groq vision model. If deprecated, pick a current one from
# https://console.groq.com/docs/models
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Option B: Anthropic Claude vision
ANTHROPIC_API_KEY=
# AI_MODEL=claude-opus-4-8

# Force a provider regardless of keys: groq | claude | mock
# AI_PROVIDER=groq

# ---- Networking ---------------------------------------------------
# HTTP port (police portal + drone app on localhost)
PORT=3000
# HTTPS port (needed for the phone camera over Wi-Fi). Default = PORT + 443.
# HTTPS_PORT=3443

# Police authorization key to clear captured drone images (default: police2026)
CLEAR_SECRET=police2026

# ---- Supabase (optional: cloud Postgres + image Storage) ----------
# If both are set, drones/alerts/dispatches live in Supabase Postgres and
# captured images go to a public Storage bucket ("drone-images", auto-created).
# If unset, the app uses a local JSON store + local image files instead.
# From Supabase → Project Settings → API:
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# One-time: run supabase/schema.sql in the Supabase SQL Editor to create the tables.
